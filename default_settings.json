{
  "uiScale": 1.0,
  "openGuideAtStartup": true,
  "topbarHelpIcon": true,
  "workspaceCount": 8,
  "wallpaperDir": "",
  "language": "us",
  "kbOptions": "grp:alt_shift_toggle",
  "monitors": [],
  "keybinds": [
    {
      "type": "bind",
      "mods": "ALT",
      "key": "F4",
      "dispatcher": "dispatch",
      "command": "hl.dsp.window.close()"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT_L",
      "key": "F",
      "dispatcher": "dispatch",
      "command": "hl.dsp.window.float()"
    },
    {
      "type": "binde",
      "mods": "$mainMod SHIFT_L",
      "key": "left",
      "dispatcher": "dispatch",
      "command": "hl.dsp.window.resize({ x = -50, y = 0 })"
    },
    {
      "type": "binde",
      "mods": "$mainMod SHIFT_L",
      "key": "right",
      "dispatcher": "dispatch",
      "command": "hl.dsp.window.resize({ x = 50, y = 0 })"
    },
    {
      "type": "binde",
      "mods": "$mainMod SHIFT_L",
      "key": "up",
      "dispatcher": "dispatch",
      "command": "hl.dsp.window.resize({ x = 0, y = -50 })"
    },
    {
      "type": "binde",
      "mods": "$mainMod SHIFT_L",
      "key": "down",
      "dispatcher": "dispatch",
      "command": "hl.dsp.window.resize({ x = 0, y = 50 })"
    },
    {
      "type": "bind",
      "mods": "$mainMod CTRL",
      "key": "left",
      "dispatcher": "dispatch",
      "command": "hl.dsp.window.move({ direction = \"l\" })"
    },
    {
      "type": "bind",
      "mods": "$mainMod CTRL",
      "key": "right",
      "dispatcher": "dispatch",
      "command": "hl.dsp.window.move({ direction = \"r\" })"
    },
    {
      "type": "bind",
      "mods": "$mainMod CTRL",
      "key": "up",
      "dispatcher": "dispatch",
      "command": "hl.dsp.window.move({ direction = \"u\" })"
    },
    {
      "type": "bind",
      "mods": "$mainMod CTRL",
      "key": "down",
      "dispatcher": "dispatch",
      "command": "hl.dsp.window.move({ direction = \"d\" })"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "left",
      "dispatcher": "dispatch",
      "command": "hl.dsp.focus({ direction = \"l\" })"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "right",
      "dispatcher": "dispatch",
      "command": "hl.dsp.focus({ direction = \"r\" })"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "up",
      "dispatcher": "dispatch",
      "command": "hl.dsp.focus({ direction = \"u\" })"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "down",
      "dispatcher": "dispatch",
      "command": "hl.dsp.focus({ direction = \"d\" })"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "RETURN",
      "dispatcher": "exec",
      "command": "kitty"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "F",
      "dispatcher": "exec",
      "command": "firefox"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "E",
      "dispatcher": "exec",
      "command": "nautilus"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "R",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/reload.sh"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "C",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh toggle clipboard"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "P",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh toggle movies"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "D",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle applauncher"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT_L",
      "key": "S",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle settings"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "Q",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle music"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "B",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle battery"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "W",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle wallpaper"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "S",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle calendar"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "N",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle network"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT_L",
      "key": "T",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle focustime"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "V",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle volume"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "H",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle guide"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "M",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/qs_manager.sh toggle monitors"
    },
    {
      "type": "bindl",
      "mods": "",
      "key": "Caps_Lock",
      "dispatcher": "exec",
      "command": "sleep 0.1 && swayosd-client --caps-lock"
    },
    {
      "type": "bindl",
      "mods": "",
      "key": "XF86MonBrightnessDown",
      "dispatcher": "exec",
      "command": "swayosd-client --brightness lower"
    },
    {
      "type": "bindl",
      "mods": "",
      "key": "XF86MonBrightnessUp",
      "dispatcher": "exec",
      "command": "swayosd-client --brightness raise"
    },
    {
      "type": "bindl",
      "mods": "",
      "key": "Print",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/screenshot.sh"
    },
    {
      "type": "bindl",
      "mods": "SHIFT_L",
      "key": "Print",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/screenshot.sh --edit"
    },
    {
      "type": "bindl",
      "mods": "$mainMod",
      "key": "Print",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/screenshot.sh --full"
    },
    {
      "type": "bindl",
      "mods": "$mainMod SHIFT_L",
      "key": "Print",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/screenshot.sh --full --edit"
    },
    {
      "type": "bindl",
      "mods": "",
      "key": "XF86PowerOff",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/lock.sh"
    },
    {
      "type": "bindel",
      "mods": "$mainMod",
      "key": "L",
      "dispatcher": "exec",
      "command": "bash ~/.config/niri/scripts/lock.sh"
    },
    {
      "type": "bindl",
      "mods": "$mainMod",
      "key": "SPACE",
      "dispatcher": "exec",
      "command": "playerctl play-pause"
    },
    {
      "type": "bindl",
      "mods": "",
      "key": "XF86AudioPause",
      "dispatcher": "exec",
      "command": "playerctl play-pause"
    },
    {
      "type": "bindl",
      "mods": "",
      "key": "XF86AudioPlay",
      "dispatcher": "exec",
      "command": "playerctl play-pause"
    },
    {
      "type": "bindl",
      "mods": "",
      "key": "xf86AudioMicMute",
      "dispatcher": "exec",
      "command": "swayosd-client --input-volume mute-toggle"
    },
    {
      "type": "bindl",
      "mods": "",
      "key": "xf86audiomute",
      "dispatcher": "exec",
      "command": "swayosd-client --output-volume mute-toggle"
    },
    {
      "type": "bindel",
      "mods": "",
      "key": "xf86audiolowervolume",
      "dispatcher": "exec",
      "command": "swayosd-client --output-volume lower"
    },
    {
      "type": "bindel",
      "mods": "",
      "key": "xf86audioraisevolume",
      "dispatcher": "exec",
      "command": "swayosd-client --output-volume raise"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "1",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 1"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "2",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 2"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "3",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 3"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "4",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 4"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "5",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 5"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "6",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 6"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "7",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 7"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "8",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 8"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "9",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 9"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "0",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 10"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT",
      "key": "1",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 1 move"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT",
      "key": "2",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 2 move"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT",
      "key": "3",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 3 move"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT",
      "key": "4",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 4 move"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT",
      "key": "5",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 5 move"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT",
      "key": "6",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 6 move"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT",
      "key": "7",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 7 move"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT",
      "key": "8",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 8 move"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT",
      "key": "9",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 9 move"
    },
    {
      "type": "bind",
      "mods": "$mainMod SHIFT",
      "key": "0",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/qs_manager.sh 10 move"
    },
    {
      "type": "bind",
      "mods": "$mainMod",
      "key": "TAB",
      "dispatcher": "exec",
      "command": "~/.config/niri/scripts/focus_next_monitor.sh"
    }
  ],
  "startup": [
    {
      "command": "/usr/lib/polkit-kde-authentication-agent-1"
    },
    {
      "command": "awww-daemon"
    },
    {
      "command": "~/.config/niri/scripts/swayidle.sh"
    },
    {
      "command": "quickshell -p ~/.config/niri/scripts/quickshell/Shell.qml"
    },
    {
      "command": "~/.config/niri/scripts/quickshell/focustime/launch_daemon.sh"
    },
    {
      "command": "~/.config/niri/scripts/init.sh"
    },
    {
      "command": "playerctld"
    },
    {
      "command": "swayosd-server --top-margin 0.9 --style \"$HOME/.config/swayosd/style.css\""
    },
    {
      "command": "wl-paste --type text --watch cliphist store"
    },
    {
      "command": "wl-paste --type image --watch cliphist store"
    },
    {
      "command": "~/.config/niri/scripts/volume_listener.sh"
    },
    {
      "command": "~/.config/niri/scripts/update_notifier.sh"
    }
  ]
}
