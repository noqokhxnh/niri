[Trigger]
Operation = Upgrade
Type = Package
Target = qt6-base
Target = glibc
Target = sqlite
Target = zbar
Target = libpng

[Action]
Description = Rebuilding Quickshell C++ Daemons to prevent library conflicts...
When = PostTransaction
Depends = gcc
Depends = pkg-config
Exec = /usr/bin/sudo -u khxnh /home/khxnh/.config/hypr/scripts/quickshell/rebuild_all.sh
